/**
 * app.wxss*
 *
 * @format
 */

@import '/font/iconfont.wxss';

@font-face {
	font-family: 'SmileySans-Oblique';
	src: url('https://siyuehanfu.dakakj.com/1.ttf');
}
image {
	height: auto;
}
page {
	background: #f5f5f5;
	/* font-family: 'DingTalk-JinBuTi'; */
	--appColor: #ef8200;
}

button[plain] {
	border: 0;
}

.app_bg {
	background: #ef8200;
}

.app_bg_title {
	background: #ef8200;
	color: #000;
}

.app_wodeyajin_title {
	background: #4bdf27;
	color: #fff;
}

.app_btn {
	background: #ef8200;
	color: #000;
	width: 100%;
	margin: 0;
	font-size: 30rpx;
}

.app_btnwodeyajin {
	background: #4bdf27;
	color: #fff;
	width: 100%;
	margin: 0;
	font-size: 30rpx;
}

.app_btn_a::after {
	border: none;
}

.btn_kefu {
	font-size: 30rpx;
	background-color: #fff;
	margin: 0;
	padding: 0;
	height: 32rpx;
	line-height: 32rpx;
}

.btn_red {
	margin: 0;
	color: #fff;
	background-color: #fe5722;
	font-size: 30rpx;
}

.app_active_tab {
	font-weight: 550;
	border-bottom: 6rpx solid crimson;
}

.app_ios {
	padding-bottom: constant(safe-area-inset-bottom);
	/*  ///兼容 IOS<11.2/ */
	padding-bottom: env(safe-area-inset-bottom);
	/* ///兼容 IOS>11.2/ */
}

.app_ios_bottom {
	bottom: constant(safe-area-inset-bottom);
	bottom: env(safe-area-inset-bottom);
}

.yhq_bg {
	/* background: url("https://hubenjun-1311982940.cos.ap-nanjing.myqcloud.com/165363463811400001.jpg") no-repeat; */
	background: url('https://hubenjun-1311982940.cos.ap-nanjing.myqcloud.com/165389155220400001.jpg')
		no-repeat;
	background-size: 100% 400rpx;
	/* background-size: cover; */
}

.yhq_bg2 {
	/* background: url("https://hubenjun-1311982940.cos.ap-nanjing.myqcloud.com/165363463811400001.jpg") no-repeat; */
	background: url('https://hubenjun-1311982940.cos.ap-nanjing.myqcloud.com/165389155220400001.jpg')
		no-repeat;
	background-size: 100%;
	/* background-size: cover; */
}

.pay_bg {
	background: url('https://hubenjun-1311982940.cos.ap-nanjing.myqcloud.com/165467848058000001.jpg')
		no-repeat;
	background-size: cover;
}
