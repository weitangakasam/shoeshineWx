.index {
  position: relative;
}
#map{
  height:100vh;
  width: 100%;
}
.g-full{
  width: 100%;
  height: 379rpx;
}
.sign_btn{
  background: #3cb035;
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  position: fixed;
  right: 5%;
  bottom: 10%;
  color: #fff;
  text-align: center;
  line-height: 130rpx;
  font-size: 35rpx;
}
.btn{
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  background: #fff;
  line-height: 130rpx;
  color: #000;
}
.fix_btn{
  position: fixed;
  color: #000;
  text-align: center;
  font-size: 28rpx;
  border-radius: 50%;
  box-shadow: 0 0 8px 0 hsl(0deg 0% 62%);
  width: 130rpx;
  height: 130rpx;
  box-sizing: border-box;
}
.time_btn{
  background: none;
  width: 100%;
  color: #fff;
  font-size: 28rpx;
  border: none;
}
.kefu_btn {
  right: 5%;
  bottom: 18%;
}
.location_btn{
  right: 5%;
  bottom: 26%;
}
.order_btn{
  right: 5%;
  bottom: 30%;
}
.cash_btn{
  left: 5%;
  bottom: 18%;
}
.time_bind{
  color: #ccc;
}
.bottom_section{
  position: fixed;
  bottom: 0px;
  height: 220rpx;
  width: 100%;
  left: 0px;
  background: #fff;
  border-top-left-radius: 60rpx;
  border-top-right-radius: 60rpx;
}

.nav{background-color:#fff;border-radius:6rpx;height:220rpx;}
.nav .item{flex:1;text-align:center;font-size:26rpx;color:#aaa;}
.nav .item .num{margin-top:10rpx;font-size:36rpx;color:#282828;}
.header-section{
  position: fixed;
  top: 130px;
  height: 150rpx;
  width: 100%;
}
.header-section .slide-image{
  height: 200rpx;
  width: 90%;
  border-radius: 110rpx;
  display: block;
  margin: 0 auto;
}
.header-section2{
  background: #fff;
  height: 120rpx;
  top: 75px;
}
.user-header{
  display: flex;
  justify-content: flex-start;
  padding-left: 30rpx;
  align-items: center;
  height: 120rpx;
}
.header-bg{
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  box-shadow: 0 0 8px 0 hsl(0deg 0% 62%);
}
.index-bg swiper{
  height: 200rpx;
}
.user-admin{
  margin-left: 30rpx;
  color: #78a797;
  font-size: 30rpx;
}
.bottom-icon{
  background-position: center;
  width: 120rpx;
  height: 120rpx;
  background-repeat: no-repeat;
  background-size: 100%;
  display: inline-block;
}
.help-icon{
  background-image: url(data:image/png;base64,);
}
.person-icon{
  background-image: url(data:image/png;base64,)
}
.scan_icon{
  background-image: url(data:image/png;base64,);
  background-position: 20rpx 20rpx;
  background-repeat: no-repeat;
  background-size: 60rpx 60rpx;
  display: inline-block;
  background-color: #4ba8e1;
  color: #fff;
  width: 250rpx;
  height: 90rpx;
  border-radius: 60rpx;
  font-size: 32rpx;
  line-height: 90rpx;
  text-align: center;
  padding-left: 60rpx;
}

.fix_btn{
  background-repeat: no-repeat;
  background-size: 100%;
  display: inline-block;
  background-position: center;
}
.fix_btn button{
  background: none;
}
.location_btn{
  background-image: url(data:image/png;base64,)
}
.order_btn {
  background-image: url(data:image/png;base64,);
  background-color: #fff;
}
.cash_btn{
  background-image: url(data:image/png;base64,);
}
.kefu_btn{
  background-image: url(data:image/png;base64,);
  background-color: #fff;
}
.open_site {
  position: absolute;
  top: 0;
  display: flex;
  width: 100%;
  justify-content: flex-end;
  align-items: center;
  font-size: 40rpx;
}
.open_site button {
  font-size: 40rpx;
  width: 200rpx;
  height: 100rpx;
  line-height: 100rpx;
  background-color: chartreuse;
  opacity: 0.6;
  z-index: 99;
}
.closeSite {
  background-position: 20rpx 20rpx;
  background-repeat: no-repeat;
  background-size: 60rpx 60rpx;
  display: inline-block;
  background-color: #f83b3b;
  color: #fff;
  width: 250rpx;
  height: 90rpx;
  border-radius: 60rpx;
  font-size: 32rpx;
  line-height: 90rpx;
  text-align: center;
}
.bangzhu view {display: flex; flex-direction: column;}
.bangzhu view text:first-child {font-size: 56rpx; color: black;}
.bangzhu view text:last-child {font-size: 26rpx; font-weight: 500; color: black;}
.site {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 99;
  text-align: center;
}
.site_title {
  background-color: #fff;
  padding: 6px;
  border-radius: 50rpx;
  font-size: 26rpx;
}
.icon-zuobiao {
  font-size: 60rpx !important;
  color: #1296db;
}
.icon-zhongdingxiang {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 50%;
  position: fixed;
  right: 50rpx;
  bottom: 260rpx;
  z-index: 999;
  font-size: 50rpx !important;
  background-color: #fff;
  text-align: center;

}