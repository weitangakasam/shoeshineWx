<navbar parameter="{{parameter}}"></navbar>
<view>
  <view style="background: #fff; margin-bottom: 30rpx; padding: 0 0 30rpx;">
    <swiper style="margin-bottom: 30rpx; height: {{imgHeight}}px;" autoplay circular	indicator-dots>
      <swiper-item wx:for="{{swiper}}">
        <image src="{{item.img}}" mode="widthFix" style="width: 100%; height: {{imgHeight}}px;" bindload="bindload" ></image>
      </swiper-item>
    </swiper>
    <view style="display: flex; padding: 0 30rpx; color: #d36d23; " bindtap="goPages"
      data-url="/paginate/rich_text/rich_text">
      <view style="background: #d36d23; color: #fff; padding: 0 6rpx; border-radius: 6rpx; margin-right: 50rpx;">公告
      </view>
      <view>新用户须知</view>
    </view>
  </view>
  <view style="padding: 0 16rpx;">
    <view style="font-weight: 800; margin-bottom: 30rpx;">附近</view>
    <view style="border: 2rpx solid #ccc; display: flex; padding: 10rpx; background: #fff; margin: 0rpx 0 16rpx 0;" bindtap="goPages"
      data-url="/pages/index/index" wx:for="{{list}}" data-item="{{item}}">
      <view style="margin: 0 20rpx 0 0;">
        <image src="{{item.img}}" style="width: 200rpx; height: 200rpx;"></image>
      </view>
      <view style="flex: 1;">
        <view style="display: flex; margin-bottom: 6rpx; justify-content: space-between;">
          <view style="font-weight: 800;">{{item.addr_name}}</view>
          <view style="width: 20%; font-size: 28rpx;">距离：{{item.distance}}</view>
        </view>
        <view style="display: flex; justify-content: space-around; margin-bottom: 10rpx;">
          <button
            style="width: 200rpx; background: #008aff; color: #fff; margin: 0; padding: 0; font-size: 30rpx;">车位数 {{item.all_count}}</button>
          <button
            style="width: 200rpx; background: #01b26a; color: #fff; margin: 0; padding: 0; font-size: 30rpx;">可用数 {{item.sure_count}}</button>
        </view>
        <view style="font-size: 28rpx; margin-bottom: 10rpx; color: #999;" wx:if="{{false}}">
          <text class="iconfont icon-qian1"> </text>
          {{item.price_y}}元{{item.base_time_x}}分钟，超出时间{{item.price_z}}元每分钟
        </view>
        <view style="font-size: 28rpx; color: #999;" data-item="{{item}}" catchtap="openLocation">
          <text class="iconfont icon-zhiyuandidian5"> </text>
          {{item.addr_location}}
        </view>
      </view>
    </view>
    <view wx:if="{{list.length == 0}}"
      style="display: flex; flex-direction: column;align-items: center; margin: 30rpx 0 0;">
      <view class="iconfont icon-wushuju" style="font-size: 100rpx;"></view>
      <text style="font-size: 30rpx;">暂无信息</text>
    </view>
  </view>
</view>