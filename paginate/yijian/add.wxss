.box {
	padding: 20rpx;
}
.form-item {
	display: flex;
	padding: 20rpx 10rpx;
}
.title {
	flex: 1;
}
.input-box {
	flex: 3;
}
.input-box input {
	border-bottom: 1px solid rgb(214, 214, 214);
}
.input-box .input {
	width: 100%;
	border-bottom: 1px solid rgb(214, 214, 214);
}
.btn {
	background-color: black;
	color: white;
	width: 100%;
} /* 页面整体容器 */
.feedback-container {
	background-color: #f7f7f7;
	min-height: 100vh;
	padding-bottom: 40rpx;
}

/* 标题栏样式 */
.title-bar {
	background-color: #ffffff;
	padding: 30rpx 40rpx;
	border-bottom: 1rpx solid #e5e5e5;
}

.title {
	font-size: 36rpx;
	font-weight: bold;
	color: #333333;
}

/* 反馈类型选择（标签页） */
.type-scroll {
	background-color: #ffffff;
	padding: 0 20rpx;
}

.type-tabs {
	display: flex;
	white-space: nowrap;
}

.type-item {
	display: inline-block;
	padding: 20rpx 30rpx;
	font-size: 28rpx;
	color: #666666;
	border-bottom: 2rpx solid transparent;
	margin-right: 20rpx;
	transition: all 0.3s ease;
}

.type-item.active {
	color: #07c160;
	border-bottom-color: #07c160;
	font-weight: 500;
}

/* 详细内容输入框 */
.input-section {
	background-color: #ffffff;
	margin: 20rpx;
	padding: 30rpx;
	border-radius: 12rpx;
}

.content-input {
	width: 100%;
	font-size: 28rpx;
	color: #333333;
	line-height: 1.6;
	background-color: #fafafa;
	border: 1rpx solid #e5e5e5;
	border-radius: 8rpx;
	padding: 20rpx;
	min-height: 200rpx;
}

.word-count {
	text-align: right;
	font-size: 24rpx;
	color: #999999;
	margin-top: 10rpx;
}

/* 图片上传区域 */
.upload-section {
	background-color: #ffffff;
	margin: 20rpx;
	padding: 30rpx;
	border-radius: 12rpx;
}

.upload-title {
	font-size: 28rpx;
	color: #333333;
	margin-bottom: 20rpx;
}

.upload-container {
	display: flex;
	flex-wrap: wrap;
	gap: 20rpx;
}

.image-item {
	width: 180rpx;
	height: 180rpx;
	position: relative;
	border-radius: 8rpx;
	overflow: hidden;
}

.preview-image {
	width: 100%;
	height: 100%;
	object-fit: cover;
}

.delete-icon {
	position: absolute;
	top: -10rpx;
	right: -10rpx;
	width: 40rpx;
	height: 40rpx;
	background-color: rgba(0, 0, 0, 0.6);
	color: #ffffff;
	border-radius: 50%;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 24rpx;
	font-weight: bold;
}

.upload-button {
	width: 180rpx;
	height: 180rpx;
	border: 2rpx dashed #dcdcdc;
	border-radius: 8rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	transition: all 0.3s ease;
}

.upload-button.disabled {
	opacity: 0.6;
	cursor: not-allowed;
}

.upload-icon {
	font-size: 60rpx;
	color: #dcdcdc;
}

/* 提交按钮 */
.submit-section {
	padding: 0 40rpx 40rpx;
}

.submit-btn {
	width: 100%;
	height: 80rpx;
	background: linear-gradient(135deg, #07c160, #06ad56);
	color: #ffffff;
	font-size: 32rpx;
	font-weight: 500;
	border-radius: 40rpx;
	border: none;
	transition: all 0.3s ease;
}

.submit-btn:hover {
	transform: translateY(-2rpx);
	box-shadow: 0 6rpx 12rpx rgba(7, 193, 96, 0.3);
}

.submit-btn:active {
	transform: translateY(0);
}

.submit-btn[disabled] {
	background: linear-gradient(135deg, #a0e0b4, #8fd8a8);
	cursor: not-allowed;
}
