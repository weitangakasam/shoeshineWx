/* paginate/hehuoren/shebei_admin.wxss */
page {
  background-color: #f5f5f5;
}
.box {
  font-size: 30rpx;
}
.search-box-bg {
  color: #fff;
  padding: 30rpx 50rpx;
}
.search-box {
  height: 80rpx;
  display: flex;
  border-radius: 14rpx;
  overflow: hidden;
}
.search-box input {
  height: 100%;
  background-color: #fff;
  flex: 3;
  margin: 0 10rpx 0 0;
  padding: 0 10rpx 0;
  color: #000;
}
.search-box button {
  flex: 1;
  background-color: #4d6ef1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  /* color: #fff; */
  margin: 0;
  padding: 0;
  border-radius: 0;
}
.main {
  background-color: #fff;
}
.list {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx 0;
  border-bottom: 2rpx solid #ddd;
}
.list_fl {
  flex: 1;
}
.list_fr {
  margin: 0 0 0 16rpx;
}
.position {
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  position: fixed;
  bottom: 80rpx;
  right: 50rpx;
  background-color: #4d6ef1;
  border-radius: 50%;
  color: #fff;
}