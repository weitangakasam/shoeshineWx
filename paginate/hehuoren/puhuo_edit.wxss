.row {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #ddd;
  padding: 10rpx 0 16rpx 0;
  margin: 0 0 16rpx 0;
}
.row_fl {
  margin:  0 30rpx 0 0;
  width: 160rpx;
}
.row_fr {
  flex: 1;
}

.add_zzc {
  height: 100vh; width: 100vw; background: #000; opacity: 0.2; position: fixed;top: 5000rpx; left: 0;
  z-index: 999; transition: all 0.3s;
}
.add_zzc2 {
  top: 0;
}
.add_info {
  position: fixed; z-index: 999; bottom: -2000rpx; left: 0; background-color: #fff;
  width: 100vw;  transition: all 0.3s;
}
.add_info2 {
  bottom: 0; transition: all 0.3s;
}
.add_top {
  display: flex; justify-content: space-between; padding: 20rpx 30rpx 10rpx; background-color: #f5f5f5;
}