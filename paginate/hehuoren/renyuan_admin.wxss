/* paginate/hehuoren/renyuan_admin.wxss */
page {background: #f5f5f5;}

.top {
  display: flex;
  justify-content: space-between;
  background: #fff;
  padding: 30rpx; margin: 0 0 15rpx 0;
}
.flex {
  display: flex; font-size: 30rpx; 
}
.top .flex input {
  height: 100%; margin: 0 4rpx 0 0; padding: 0 0rpx 0rpx 15rpx;
  border: 2rpx solid #808080; box-sizing: border-box; border-top-left-radius: 10rpx;
  border-bottom-left-radius: 10rpx;
}
.add {
  width: 135rpx !important; padding: 0; 
  height: 70rpx; margin:  0 30rpx 0 0 !important;
  line-height: 65rpx;
  font-size: 30rpx;
  /* background-color: #4d6ef1; */
  color: #fff; 
}
.search {
  flex: 1;
   border-radius: 0;
  width: 135rpx; padding: 0; margin: 0;
  height: 100%;  font-size: 30rpx;
  line-height: 65rpx;
  /* background-color: #4d6ef1; */
  color: #fff;
}
.list {
  display: flex; justify-content: space-between; padding: 0 30rpx;
  font-size: 30rpx; border-bottom: 2rpx solid #ddd; margin-bottom: 16rpx;
}
.list_fl_view {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}
.list_fr {
  display: flex;align-items: center;
}
.list_fr button{
  width: 290rpx; height: 60rpx; line-height: 60rpx; color: #fff;
  margin: 0 0 15rpx 0;
  font-size: 30rpx;
}
/* 分页 */
.fenye {
  width: 100%rpx; height: 60rpx; overflow: hidden; transition: all 0.5s; box-sizing: border-box;
  display: flex; font-size: 30rpx; align-items: center;  justify-content: flex-end; padding: 0 20rpx;
}
.fenye_num {
  width: 60rpx; margin: 0 20rpx 0 0; font-size: 30rpx; flex-shrink: 0;
  height: 60rpx; color: #fff;
  text-align: center; line-height: 60rpx; background: #ccc;
}
.pageActive {
  background: #009888 !important
}
/* 分页结束 */
.add_zzc {
  height: 100vh; width: 100vw; background: #000; opacity: 0.2; position: fixed;top: 5000rpx; left: 0;
  z-index: 999; transition: all 0.3s;
}
.add_zzc2 {
  top: 0;
}
.add_info {
  position: fixed; z-index: 999; bottom: 0; left: 0; background-color: #fff;
  width: 100vw; transition: all 0.3s; padding-bottom: 20rpx;
}
.add_info2 {
  bottom: 0; transition: all 0.3s;
}
.add_top {
  display: flex; justify-content: space-between;  padding: 20rpx 30rpx 10rpx; background-color: #f5f5f5;
}
.row {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #ddd;
  padding: 10rpx 0 16rpx 0;
  margin: 0 0 16rpx 0;
}
.row_fl {
  margin:  0 30rpx 0 0;
  width: 230rpx;
}
.row_fr {
  flex: 1;
}
.add_btn {
  width: 160rpx; height: 75rpx; font-size: 30rpx; color: #fff; padding: 0; margin: 0 30rpx 0 0; border-radius: 8rpx;
}