.uploader__input-box {
	border-radius: 20rpx;
	width: 100%;
	height: 45vw;
}
/* 容器样式（横向排列多个项目时用） */
.icon-text-container {
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	height: 100%;
}

/* 图标容器（可选：用于角标定位） */
.icon-wrapper {
	position: relative;
	margin-bottom: 40rpx; /* 图标与文字的间距 */
}

/* 图标样式 */
.icon {
	width: 100%; /* 图标大小 */
	height: 100%;
}

/* 文字样式 */
.text {
	font-size: 24rpx;
	color: #333; /* 文字颜色 */
	text-align: center;
	line-height: 1.4;
}

/* 角标样式（可选） */
.badge {
	position: absolute;
	top: -10rpx;
	right: -10rpx;
	min-width: 30rpx;
	height: 30rpx;
	background: #ff0000;
	color: white;
	font-size: 20rpx;
	border-radius: 50%;
	display: flex;
	justify-content: center;
	align-items: center;
	padding: 0 8rpx;
}

/* 点击反馈效果 */
.icon-text-container:active {
	opacity: 0.7;
}
