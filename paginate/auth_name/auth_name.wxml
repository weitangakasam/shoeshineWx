<navbar parameter='{{parameter}}'></navbar>
<view class="box">
  <form action="" bindsubmit="submitForm">
    <view class="row">
      <view class="row_fl">
        <text style="color:red;">*</text>姓名
      </view>
      <view class="row_fr">
        <input type="text" name="realname" placeholder="请输入姓名" />
      </view>
    </view>
    <view class="row">
      <view class="row_fl">
        <text style="color:red;">*</text>身份证号
      </view>
      <view class="row_fr">
        <input type="text" name="id_card" placeholder="请输入身份证号" />
      </view>
    </view>
    <view class="row" wx:if="{{false}}">
      <view class="row_fl">
        <text style="color:red;">*</text>确认密码
      </view>
      <view class="row_fr">
        <input type="password" name="password2" placeholder="请输入确认密码" />
      </view>
    </view>
    <view class="row" wx:if="{{false}}">
      <view class="row_fl">
        <text style="color:red;">*</text>电话
      </view>
      <view class="row_fr flex_sw">
        <input type="text" name="mobile" placeholder="请输入电话" />
      </view>
    </view>
    <view class="row" wx:if="{{false}}">
      <view class="row_fl">
        <text style="color:red;">*</text>经营地区
      </view>
      <view class="row_fr flex_sw">
        <!-- <input type="text" name="address" placeholder="请输入意向经营地区" /> -->
        <picker mode="multiSelector" bindchange="bindMultiPickerChange" bindcolumnchange="bindMultiPickerColumnChange"
          value="{{multiIndex}}" range="{{multiArray}}" style="width:100%;" >
          <view wx:if="{{city_id.city_id}}">
           {{multiArray[0][multiIndex[0]]}}，{{multiArray[1][multiIndex[1]]}}，{{multiArray[2][multiIndex[2]]}}
          </view>
          <view wx:else>
           <text style="color: #999; width: 100%;">请选择经营地区</text>
          </view>
        </picker>
      </view>
    </view>
    <view class="row" wx:if="{{false}}">
      <view class="row_fl">
        <text style="color:red;">*</text>经营地区
      </view>
      <view class="row_fr flex_sw">
        <input type="text" disabled value="{{position}}" bindtap="getPostion" placeholder="请选择经营地区" />
        <view class="iconfont icon-zhiyuandidian5"></view>
      </view>
    </view>
    <button class="app_btn btn" hover-class="app_btn_hover" form-type="submit" style="width: 100%;">提交</button>
  </form>
</view>