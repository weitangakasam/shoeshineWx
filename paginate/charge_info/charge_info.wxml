<import src="../../wxParse/wxParse.wxml"></import>
<navbar parameter="{{ parameter }}"></navbar>
<view class="charge_info">
	<!-- 轮播图 -->
	<view style="padding: 30rpx; position:relative;">
		<view style="font-size: 36rpx; font-weight: 550; margin: 0 0 20rpx" wx:if="{{ false }}">
			<text>自带三线</text>
			<text style="color: #2bd966;">适配所有手机</text>
		</view>
		<view style="color: #808080;" wx:if="{{ false }}">
			<text>苹果 · Type-C · 安卓</text>
		</view>
		<view style="width: 370rpx; margin: 30rpx auto">
			<image mode="widthFix" style="width: 100%" src="/paginate/img/charge.png" />
		</view>
	</view>
	<!-- 充电宝信息 -->
	<view class="fixed">
		<view class="row">
			<view class="row_fl">
				<view class="iconfont icon-dingwei"></view>
			</view>
			<view class="row_fr">
				<view>{{info.name}}</view>
				<view>{{info.addr_location || '信息异常'}}</view>
			</view>
		</view>
		<view wx:if="{{ 0 }}" class="row" style="margin-bottom: 26rpx">
			<view class="row_fl">
				<view class="iconfont icon-chongzhi0101"></view>
			</view>
			<view class="row_fr" style="display: flex; justify-content: space-between; align-items: center;">
				<view>押金 ￥{{ ya_jin }}</view>
				<view>
					<radio-group bindchange="yagree">
						<radio checked="{{ payCode }}"></radio>
					</radio-group>
				</view>
			</view>
		</view>
		<view class="row">
			<view class="row_fl">
				<view class="iconfont icon-qian1"></view>
			</view>
			<view class="row_fr">
				<view>{{money || 0.01}}元/{{time}}分钟</view>
				<view style="margin: 6rpx 0 0 0">{{free_time}}分钟内归还免费,超出{{free_time}}分钟计入收费时长</view>
				<view style="margin: 6rpx 0 0 0; font-size: 24rpx; color: #808080;">不足{{time}}分钟按{{time}}分钟计算</view>
				<view style="margin: 6rpx 0 0 0; font-size: 24rpx; color: #808080;">
					<!-- 押金200元，支持免押服务 -->
					租借最长时间为2天，请及时归还
				</view>
			</view>
		</view>
		<view class="row" style="margin-bottom: 26rpx">
			<view class="row_fl">
				<view class="iconfont icon-zhima-chongdianbao"></view>
			</view>
			<view class="row_fr">
				<view>设备工具，原柜门借还</view>
			</view>
		</view>
