      <view class="row_fl">
        <view class="iconfont icon-zhima-chongdianbao">
        </view>
      </view>

      <view class="row_fr">
        <view>
          支付方式
        </view>

      <view class="change">
  <radio-group class="block lang_btn" bindchange="changeLanguage">
    <view class="cu-form-group margin-top">
      <view class="left_v">
        <view class="title">微信支付分|免充值</view>
      </view>
      <radio checked="{{lang=='1'?true:false}}" value='1'></radio>
    </view>
    <view class="cu-form-group margin-top">
      <view class="left_v">
        <view class="title">押金支付( 剩余押金0)</view>
      </view>
      <radio checked="{{lang=='2'?true:false}}" value='2'></radio>
    </view>
  </radio-group>
</view>

      </view>

    </view> -->
		<!-- 协议 -->
		<view class="xieyi">
			<view class="update">
				<view>相关协议已更新， 请查看</view>
			</view>
			<fui-checkbox-group name="checkbox" bindchange="change">
				<view class="fui-list__item">
					<fui-label>
						<view class="fui-align__center">
							<fui-checkbox checked="{{ isAgree }}" value="1"></fui-checkbox>
							<view class="protocol">
								<text>点击同意</text>
								<text bindtap="isHidden" data-text="user_agreement">《用户协议》</text>
								<text bindtap="isHidden" data-text="privacy_policy"> 《隐私政策》</text>
							</view>
						</view>
					</fui-label>
				</view>
			</fui-checkbox-group>
		</view>
		<button wx:if="{{ 0 }}" size="default" type="primary" class="zujie" data-type="goPages" bindtap="goPages">
			<view style="height: 30rpx; line-height: 30rpx;">免押金租借</view>
			<view style="display: flex; align-items: center; justify-content: center;">
				<image src="/paginate/img/lan.png" style="width: 50rpx; height: 50rpx; margin: 0 6rpx 0 0;"></image>
				微信支付分 |
				550分及以上优享
			</view>
		</button>
		<button size="default" type="primary" class="zujie" data-type="goPages1" bindtap="goPages1" style="margin-top: 10px;">
			<view style="height: 30rpx; line-height: 30rpx;">押金支付 ¥{{ ya_jin }}</view>
			<view style="display: flex; align-items: center; justify-content: center;">
				<image src="/paginate/img/lan.png" style="width: 50rpx; height: 50rpx; margin: 0 6rpx 0 0;"></image>
				剩余押金 |
				¥{{userInfo.yajin_money}}
			</view>
		</button>
	</view>
	<!-- 用户协议 --  隐私政策 -->
	<page-container show="{{ !hidden }}" round bind:beforeleave="beforeleave">
		<view class="fuwenben app_ios" style="max-height: 100vh; overflow-y: auto;">
			<view style="position: fixed; right: 40rpx;">
				<text class="iconfont icon-quxiao" bindtap="isHidden"></text>
			</view>
			<block wx:if="{{ isSelectProduct }}">
				<view style="padding-top: 40rpx;">
					<radio-group class="radio-group" bindchange="radioChange">
						<view class="attr_value">
							<radio class="radio" value="A" checked="{{ product==='A' }}">
								<view style="display: flex;align-items: center; gap: 20rpx;flex-direction: column;">
									<view>{{info.product_a}}</view>
									<image class="" src="/images/yang.png" mode="heightFix" style="height: 32vh" lazy-load="false" binderror="" bindload=""></image>
								</view>
							</radio>
							<radio class="radio" value="B" checked="{{ product==='B' }}">
								<view style="display: flex;align-items: center; gap: 20rpx;flex-direction: column;">
									{{info.product_b}}
									<image class="" src="/images/guang.png" mode="heightFix" style="height: 32vh" lazy-load="false" binderror="" bindload=""></image>
								</view>
							</radio>
						</view>
					</radio-group>
					<view style="display: flex;">
						<button bind:tap="confrim" type="primary">确认</button>
						<button bindtap="isHidden" type="warn">取消</button>
					</view>
				</view>
			</block>
			<block wx:else>
				<view style="padding-top: 40rpx;">
					<template is="wxParse" data="{{ wxParseData:user_agreement.nodes }}" wx:if="{{ nodes == 'user_agreement' }}"></template>
					<template is="wxParse" data="{{ wxParseData:privacy_policy.nodes }}" wx:if="{{ nodes == 'privacy_policy' }}"></template>
				</view>
			</block>
		</view>
	</page-container>
</view>
<authorize iShidden="{{ iShidden }}" bind:onLoadFun="onLoadFun"></authorize>