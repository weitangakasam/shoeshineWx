<navbar parameter="{{ parameter }}"></navbar>
<view class="title">录入商户后，自动添加到当前商户下级</view>
<form bindsubmit="submit">
	<view class="input">
		<view class="require">手机号</view>
		<input type="number" name="mobile" value="{{ params.mobile }}" placeholder="请录入手机号" placeholder-style="text-align:left;color: rgba(108, 108, 108, 1);" />
	</view>
	<view class="input">
		<view class="require">用户名</view>
		<input name="n" type="text" value="{{ params.username }}" placeholder="请录入用户名" placeholder-style="text-align:left;color: rgba(108, 108, 108, 1);" />
	</view>
	<view class="input">
		<view class="require">登录密码</view>
		<input type="password" value="{{ params.password }}" name="password" placeholder="请录入登录密码" placeholder-style="text-align:left;color: rgba(108, 108, 108, 1);" />
	</view>
	<view class="input">
		<view class="require">确认密码</view>
		<input type="password" value="{{ params.password2 }}" name="password2" placeholder="请录入确认密码" placeholder-style="text-align:left;color: rgba(108, 108, 108, 1);" />
	</view>
	<view class="input">
		<view class="require">经营地区</view>
		<picker class="picker" mode="multiSelector" bindchange="bindMultiPickerChange" bindcolumnchange="bindMultiPickerColumnChange" value="{{ multiIndex }}" range="{{ multiArray }}">
			<view wx:if="{{ form.city_id }}">
				{{multiArray[0][multiIndex[0]]}}，{{multiArray[1][multiIndex[1]]}}，{{multiArray[2][multiIndex[2]]}}
			</view>
			<view wx:else>
				<text style="color: #999;">请选择经营地区</text>
			</view>
		</picker>
	</view>
	<view class="input">
		<view class="require">分成比例</view>
		<input value="{{ params.rate }}" placeholder="0-100" type="digit" name="rate" placeholder-style="text-align:left;color: rgba(108, 108, 108, 1);" />
	</view>
	<button form-type="submit">提交</button>
</form>