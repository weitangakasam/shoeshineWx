.rent {
	padding: 30rpx;
}
/* 点加载动画容器 */
.dot-loading {
	display: flex;
	justify-content: center;
	align-items: center;
	height: 40rpx;
}

/* 单个点的基本样式 */
.dot {
	width: 12rpx;
	height: 12rpx;
	border-radius: 50%;
	background-color: #000; /* 绿色，可修改 */
	margin: 0 6rpx;
	opacity: 0.3;
}

/* 三个点的动画效果 */
.dot:nth-child(1) {
	animation: dot-pulse 1.4s infinite;
}
.dot:nth-child(2) {
	animation: dot-pulse 1.4s infinite 0.2s;
}
.dot:nth-child(3) {
	animation: dot-pulse 1.4s infinite 0.4s;
}

@keyframes dot-pulse {
	0%,
	100% {
		opacity: 0.3;
		transform: scale(0.75);
	}
	50% {
		opacity: 1;
		transform: scale(1);
	}
}

.rent .top {
	display: flex;
	justify-content: space-between;
	align-items: center;
	margin: 0 0 30rpx;
}
.rent .top view:nth-child(1) {
	font-size: 36rpx;
	font-weight: 550;
}
.rent .card {
	background-color: #fff;
	border-radius: 16rpx;
	padding: 30rpx;
}
.rent .card_title {
	display: flex;
	padding-bottom: 20rpx;
	border-bottom: 2rpx solid #ccc;
}
.rent .card_title view:nth-child(1) {
	margin-right: 90rpx;
}
.rent .card_info {
	margin: 20rpx 0 0;
}
.rent .card_info view:nth-child(1) {
	font-weight: 550;
	font-size: 30rpx;
	/* margin: 0 0 10rpx; */
}
.rent .card_info view:nth-child(2) {
	color: #808080;
}
