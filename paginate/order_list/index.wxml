<navbar parameter='{{parameter}}'></navbar>
<view class='my-order'>
  <view class='header bg-color'>
    <view class='picTxt acea-row row-between-wrapper' style="display: flex;align-items: center; justify-content: flex-end;">
      <view class='text'>
        <!-- <view class='name'>订单信息</view> -->
        <!-- <view>消费订单：{{orderData.order_count || 0}} 总消费：￥{{orderData.sum_price || 0}}</view> -->
      </view>
      <view class='pictrue'>
        <image src='/paginate/img/orderTime.png'></image>
      </view>
    </view>
  </view>
  <view class='nav acea-row row-around' style="display: flex;">
    <view class='item {{orderStatus== 0 ? "on": ""}}' data-status="0" bindtap="statusClick" style="flex: 1;">
      <view>全部订单</view>
      <!-- <view class='num'>{{orderData.unpaid_count || 0}}</view> -->
    </view>
    <view class='item {{orderStatus==3 ? "on": ""}}' data-status="3" bindtap="statusClick" style="flex: 1;">
      <view>待付款</view>
      <!-- <view class='num'>{{orderData.unpaid_count || 0}}</view> -->
    </view>
    <!-- <view class='item {{orderStatus== "PS_WAITTING" ? "on": ""}}' data-status="PS_WAITTING" bindtap="statusClick">
      <view>待发货</view>
      <view class='num'>{{orderData.unshipped_count || 0}}</view>
    </view> -->
    <view class='item {{orderStatus== 1 ? "on": ""}}' data-status="1" bindtap="statusClick" style="flex: 1;">
      <view>使用中</view>
      <!-- <view class='num '>{{orderData.received_count || 0}}</view> -->
    </view>
    <view class='item {{orderStatus==2 ? "on": ""}}' data-status="2" bindtap="statusClick" style="flex: 1;">
      <view>已完成</view>
      <!-- <view class='num'>{{orderData.evaluated_count || 0}}</view> -->
    </view>
  </view>
  <scroll-view scroll-y="true" bindscrolltolower="handleBottom" style="height: calc(100vh - 280rpx - {{parameter.navH}}rpx);">
    <view class='list'>
      <view class='item' wx:for="{{orderList}}" wx:key="index">
      <!-- bindtap='goOrderDetails' -->
        <view data-order_id="{{item.id}}">
          <view class='title acea-row row-between-wrapper' style="display: flex; align-items: center;">
            <view class="acea-row row-middle">
              <text class="sign cart-color acea-row row-center-wrapper" >{{item.status}}</text>
            </view>
            <view class='totalPrice'>
              <text class='money' wx:if="{{item.status == '已退还'}}">费用合计￥{{item.money || 0}}</text>
            </view>
          </view>
          <view class='item-info acea-row row-between row-top' style="font-size: 30rpx;">
            <view style="display: flex;"><view style="width: 160rpx;">设备名称：</view> <view style="flex: 1;">{{item.site_name}}</view> </view>
            <view style="display: flex;"><view style="width: 160rpx;">设备地址：</view> <view style="flex: 1;">{{item.addr_location}}</view> </view>
            <view style="display: flex;"><view style="width: 160rpx;">支付单号：</view> <view style="flex: 1;">{{item.pay_code}}</view> </view>
            <view style="display: flex;"><view style="width: 160rpx;">支付金额：</view> <view style="flex: 1; color: red;">￥{{item.total_money}}</view> </view>
            <view style="display: flex;"><view style="width: 160rpx;">订单编号：</view> <view style="flex: 1; display: flex; align-items: center;"><text style="margin: 0 30rpx 0 0;">{{item.pay_code}}</text> <view catchtap="Paste" style="width: 60rpx; color: #999; font-size: 24rpx;" >复制</view></view>  </view>
            <view style="display: flex;"><view style="width: 160rpx;">开始时间：</view> <view style="flex: 1;">{{item.begin_time}}</view> </view>
            <view style="display: flex;" wx:if="{{item.status != '使用中'}}"><view style="width: 160rpx;">结束时间：</view> <view style="flex: 1;">{{item.end_time}}</view> </view>
          </view>
          <!-- <view class='item-info acea-row row-between row-top' wx:for="{{item.goods_info}}" wx:key>
            <view class='pictrue'>
              <image src='{{item.img}}'></image>
            </view>
            <view class='text acea-row row-between'>
              <view class='name line2'>{{item.title}}</view>
              <view class='money'>
                <view wx:if="{{item.speces || item.attrs}}">{{item.speces}} {{item.attrs}}</view>
                <view wx:else>￥{{item.price}}</view>
                <view>x{{item.count}}</view>
              </view>
            </view>
          </view> -->
        </view>
        <view class='bottom acea-row row-right row-middle' style="dispaly:none" wx:if="{{false}}">
          <view class='bnt cancelBnt' wx:if="{{item.status == '待付款'}}" data-index="{{index}}" data-order_id="{{item.id}}" bindtap='cancelOrder'>取消订单</view>
          <view class='bnt bg-color' wx:if="{{item.status == '待付款'}}" data-pay_code="{{item.pay_code}}" data-order_id="{{item.id}}" data-pay_money="{{item.total_money}}" bindtap='goPay'>立即付款</view>

          <view class='bnt bg-color' wx:if="{{false}}" data-pay_price="{{item.pay_price}}" data-order_id="{{item.id}}"bindtap='goOrderDetails'>查看详情</view>

          <view class='bnt bg-color' wx:if="{{false}}" data-pay_price="{{item.pay_price}}" data-order_id="{{item.id}}"bindtap='confirmOrder'>确认收货</view>
          
          <block wx:if="{{false}}">
              <view catch:tap="toReview" class="bnt bg-color"  data-id="{{item.id}}"  data-event-type="jsPost" data-href="wmall/order/index/cancel?id={{item.id}}" data-success-url="detail?id={{item.id}}">去评价</view>
          </block>
          <block wx:if="{{false}}" >
              <!-- <view catch:tap="refundOrder" class="cardbutton btn refund bg_red"  data-id="{{item.id}}"  data-event-type="jsPost" >申请售后</view> -->
              <!-- <view class='bnt bg-color' catch:tap="delOrder" class="cardbutton btn bg_red"  data-id="{{item.id}}"  data-index = "{{index}}" data-event-type="jsPost" >删除</view> -->
              <view  class="cardbutton bnt" data-event-type="jsUrl" >已评价</view>
          </block>
        </view>
      </view>
    </view>
    <view class='noCart' wx:if="{{orderList.length == 0}}">
      <view class='pictrue'>
      <image src='/images/noOrder.png'></image>
     </view>
</view>
  </scroll-view>
  <view class='loadingicon acea-row row-center-wrapper' wx:if="{{loading}}">
    <text class='loading iconfont icon-jiazai' hidden='{{loading==false}}'></text>{{loadTitle}}
  </view>
</view>
<authorize bind:onLoadFun='onLoadFun'></authorize>
<payment payMode='{{payMode}}' pay_close="{{pay_close}}" bind:onChangeFun='onChangeFun' order_id="{{pay_order_id}}" totalPrice='{{totalPrice}}'></payment>