<view class="tab-content-item">
  <view wx:if="{{false}}" class="header f-28 col-3">
    <view bindtap="bindHeaderTap" class="{{dataType==='售货机'?'active':''}}" data-type="售货机">
      <text>售货机</text>
    </view>
    <view bindtap="bindHeaderTap" class="{{dataType==='租赁机'?'active':''}}" data-type="租赁机">
      <text>租赁机</text>
    </view>
    <!-- <view bindtap="bindHeaderTap" class="{{dataType==='FINISHED'?'active':''}}" data-type="FINISHED">
      <text>待评价</text>
    </view> -->
  </view>
  <!-- 订单列表 -->
  <view wx:if="{{isLogin}}" class="goods-detail-box">
    <view>
      <view class="wrapper" wx:if="{{orderList.length > 0}}">
        <view class="m-top20" wx:for="{{orderList}}" wx:key="this" catchtap="navigateToDetail" data-id="{{item.order_id}}">
          <view class="order-box b-f" wx:if="{{false}}">
            <view class="order-header dis-flex">
              <view class="flex-box t-l" >
                <text class="title" >{{item.device_name}}</text>
              </view>
              <view class="flex-box t-r">
                <text class="cont">{{item.status}}</text>
              </view>
            </view>
          </view>
          <view class="order-box order-img_list">
            <view class="order-shop">
              <view class="order-list-box dis-flex">
                <view class="left" style="color: #808080;">
                  <view class="dis-flex" style="font-size: 30rpx;margin: 0 0 6rpx;">
                    使用时间：{{item.create_time}}
                  </view>
                  <view class="dis-flex" style="font-size: 30rpx;">
                    <view wx:if="{{item.price > 0}}"><text >优惠金额：</text> <text style="color: red;">￥{{item.price}}</text></view>
                    <view wx:if="{{item.rate > 0}}">
                      <text >优惠折扣：</text> <text style="color: red;">{{item.rate}}</text>
                    </view>
                  </view>
                </view>
                <view class="right dis-flex flex-x-center flex-y-center">
                  <!-- <text class="goods-number">共{{item.count}}件</text>
                  <text class="iconfont icon-xiangyoujiantou user-orderJtou"></text> -->
                </view>
              </view>
            </view>
          </view>
          <!-- <view class="order-box b-f">
                  <view class="order-cont dis-flex">
                    <view class="order-num">
                      <text>序列号 : {{item.goods[0].ordercode}}</text>
                    </view>
                  </view>
                </view> -->
          <view class="order-box b-f" wx:if="{{false}}">
            <view class="order-btn dis-flex">
              <view class="order-left">
                <view class="text">
                  <text>支付金额：</text>
                  <text class="col-m">￥{{item.total_money}}</text>
                </view>
              </view>
              <view class="order-right" style="flex: 5;">
                <view class="btn-group dis-flex" wx:if="{{item.status != '待付款'}}">
                  <view style="display: flex;">
                    <view class="btn-default" data-id="{{item.order_id}}" style="margin: 0 10rpx 0 10rpx"> <button open-type="contact" class="btn_kefu" style="color: #999; background: #fff;">客服</button>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view wx:else>
        <view class="yoshop-notcont">
          <text class="iconfont icon-wushuju"></text>
          <text class="cont">亲，您还没有使用信息哦！</text>
        </view>
      </view>
      <view wx:if="{{ no_more }}" class="no-more f-30">亲, 没有更多了</view>
    </view>
  </view>
  <view wx:else style="text-align:center;padding:20rpx;">
    请先登录
  </view>
</view>

<!-- 填写物流信息 -->
<view wx:if="{{isSetInfo}}" style="position: fixed; top: 0; left: 0; height: 100vh; box-sizing: border-box;">
  <view style="background: #000; opacity: 0.3; width: 100vw; height: 100vh; overflow: hidden;"></view>
  <form bindsubmit="submitSetInfo" style="width: 600rpx; z-index: 999; padding: 30rpx; box-sizing: border-box;  background: #f5f5f5; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); border-radius: 20rpx; overflow: hidden; font-size: 30rpx;">
    <view style="margin: 0 0 30rpx 0;">
      <textarea style="width: 100%; min-height: 90rpx; background: #fff;" bindblur="bindTextAreaBlur" auto-height placeholder="请输入申诉内容" />
    </view>
    <view style="display: flex;">
      <button style="background: #fd4a5f; font-size: 30rpx;color: #f5f5f5;" formType="submit">确定</button>
      <button style="background: #fd4a5f; font-size: 30rpx;color: #f5f5f5;" bindtap="cancelSetInfo">取消</button>
    </view>
  </form>
</view>
<!-- 加工信息 -->
<view wx:if="{{isReadInfo}}" style="position: fixed; top: 0; left: 0; height: 100vh; box-sizing: border-box;">
  <view style="background: #000; opacity: 0.3; width: 100vw; height: 100vh; overflow: hidden;"></view>
  <form bindsubmit="submitSetInfo" style="width: 600rpx; z-index: 999; padding: 30rpx; box-sizing: border-box;  background: #fff; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); border-radius: 20rpx; overflow: hidden; font-size: 30rpx;">
    <view style="margin: 0 0 30rpx 0; display: flex;">
      <view style="margin: 0 30rpx 0 0; width: 180rpx; text-align: right;">姓名：</view>
      <view>{{readInfo.name}}</view>
    </view>
    <view style="margin: 0 0 30rpx 0; display: flex;">
      <view style="margin: 0 30rpx 0 0; width: 180rpx; text-align: right;">手机号：</view>
      <view>{{readInfo.mobile}}</view>
    </view>
    <view style="margin: 0 0 30rpx 0; display: flex;">
      <view style="margin: 0 30rpx 0 0; width: 180rpx; text-align: right;">地址：</view>
      <view>{{readInfo.addr}} </view>
    </view>
    <view style="margin: 0 0 30rpx 0; display: flex;">
      <view style="margin: 0 30rpx 0 0; width: 180rpx; text-align: right;">加工方姓名：</view>
      <view>{{readInfo.shopname}}</view>
    </view>
    <view style="display: flex;">
      <button style="background: #fd4a5f; font-size: 30rpx;color: #f5f5f5;" bindtap="cancelSetInfo">关闭</button>
      <!-- <button formType="submit">确定</button> -->
    </view>
  </form>
</view>
<!-- 加工物流信息 -->
<view wx:if="{{isSkQrcode}}" style="position: fixed; top: 0; left: 0; height: 100vh; box-sizing: border-box;">
  <view style="background: #000; opacity: 0.3; width: 100vw; height: 100vh; overflow: hidden;"></view>
  <form bindsubmit="submitSetInfo" style="width: 600rpx; z-index: 999; padding: 30rpx; box-sizing: border-box;  background: #fff; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); border-radius: 20rpx; overflow: hidden; font-size: 30rpx;">
    <image mode="widthFix" style="width: 70%; display: block; margin: 0 auto 30rpx;" src="{{skQrcodeInfo}}"></image>
    <view style="display: flex;">
      <button style="background: #fd4a5f; font-size: 30rpx;color: #f5f5f5;" bindtap="cancelSetInfo">关闭</button>
      <!-- <button formType="submit">确定</button> -->
    </view>
  </form>
</view>
<!-- CAD地址 -->
<view wx:if="{{isCadInfo}}" style="position: fixed; top: 0; left: 0; height: 100vh; box-sizing: border-box;">
  <view style="background: #000; opacity: 0.3; width: 100vw; height: 100vh; overflow: hidden;"></view>
  <form bindsubmit="submitSetInfo" style="width: 600rpx; z-index: 999; padding: 30rpx; box-sizing: border-box;  background: #fff; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); border-radius: 20rpx; overflow: hidden;">
    <view style="margin: 0 0 30rpx 0; display: flex;" wx:for="{{cadInfo}}">
      <view style="word-break:break-all; font-size: 30rpx; color: #777;" bindtap="copy" data-value="{{item}}">{{item}}
      </view>
    </view>
    <view style="display: flex;">
      <button style="background: #fd4a5f; font-size: 30rpx;color: #f5f5f5;" bindtap="cancelSetInfo">关闭</button>
      <!-- <button formType="submit">确定</button> -->
    </view>
  </form>
</view>

<!-- 返回顶部 -->
<view class="goTop" bindtap="goTop" wx:if="{{isTop}}">↑</view>
<!-- 支付弹窗 -->
<payment payMode='{{payMode}}' pay_close="{{pay_close}}" bind:onChangeFun='onChangeFun' pay_code="{{pay_code}}" order_id="{{pay_order_id}}" totalPrice='{{totalPrice}}'></payment>