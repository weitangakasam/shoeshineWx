<navbar parameter='{{parameter}}'></navbar>
<view class="app_ios">
  <view style="padding: 30rpx 30rpx 0; font-size: 30rpx;">
    <form bindsubmit="sure">
      <view style="padding: 0 0 30rpx;">
        <view style="font-size: 30rpx; margin-bottom: 20rpx; font-weight: 800;">点击扫描设备二维码或手动输入</view>
        <view bindtap="scan"
          style="background: #e1f2ff; height: 96rpx; display: flex; justify-content: center; align-items: center; color: #95ddd9;">
          <text class="iconfont icon-saoyisao" style="margin: 0 30rpx 0 0; font-size: 50rpx;"></text>
          <text>请扫描设备二维码并且核对ID</text>
        </view>
      </view>
      <view
        style="border-radius: 10rpx; background: #fff;margin-bottom: 30rpx; padding: 20rpx; display: flex; justify-content: space-between;">
        <view style="width: 200rpx;">设备号</view>
        <view><input type="number" name="only_code" placeholder="请扫码或手动输入设备号" bindinput="changeInput"
            data-name="only_code" value="{{params.only_code}}" /></view>
      </view>
      <view style="font-size: 30rpx; margin-bottom: 30rpx; font-weight: 800;">请选择故障类型</view>
      <radio-group bindchange="radioChange" name="type"
        style="display: flex; margin-bottom: 30rpx; flex-wrap: wrap; background: #fff; border-radius: 10rpx; padding: 20rpx 20rpx 0;">
        <view wx:for="{{radioList}}" wx:key="{{item.name}}"
          style="width: 50%; height: 60rpx; line-height: 60rpx; margin-bottom: 20rpx;">
          <label class="weui-cell weui-check__label">
            <view style="display: flex;">
              <radio value="{{item.name}}" />
              <view class="weui-cell__bd">{{item.name}}</view>
            </view>
          </label>
        </view>
      </radio-group>
      <view style="border-radius: 10rpx; background: #fff;margin-bottom: 30rpx; height: 200rpx; padding: 20rpx;">
        <textarea type="text" name="info" placeholder="请填写报障详细原因" style="width: 100%; height: 100%;" />
      </view>
      <view style="border-radius: 10rpx; background: #fff;margin-bottom: 30rpx; min-height: 200rpx; padding: 20rpx;">
        <view style="display: flex; margin-bottom: 20rpx; flex-wrap: wrap;">
          <view style="margin: 0 20rpx 0 0; position: relative;" wx:if="{{params.imgs.length != 0}}"
            wx:for="{{params.imgs}}">
            <image style="width: 150rpx; height: 150rpx;" src="{{item}}"></image>
            <view
              style="position: absolute; right: -8rpx; top: -8rpx; background: #ccc; color: #fff; border-radius: 50%; width: 40rpx; height: 40rpx;display: flex; justify-content: center;align-items: center;"
              catchtap="del" data-index="{{index}}">
              <text class="iconfont icon-quxiao" style="font-size: 20rpx !important;margin: 0;"></text>
            </view>
          </view>
          <view
            style="width: 150rpx; height: 150rpx; box-sizing: border-box; display: flex; flex-direction: column; align-items: center; justify-content: center; border: 1rpx solid #ccc; padding: 16rpx;"
            bindtap="chooseMedia">
            <view style="font-size: 52rpx;" class="iconfont icon-jiahao"></view>
          </view>
        </view>
        <view style="font-size: 28rpx; color: #999;">上传图片</view>
      </view>
      <view
        style="border-radius: 10rpx; background: #fff;margin-bottom: 20rpx; padding: 20rpx; display: flex; justify-content: space-between;">
        <view style="width: 200rpx;">联系人</view>
        <view><input type="text" name="name" placeholder="请输入联系人" /></view>
      </view>
      <view
        style="border-radius: 10rpx; background: #fff;margin-bottom: 20rpx; padding: 20rpx; display: flex; justify-content: space-between;">
        <view style="width: 200rpx;">联系电话</view>
        <view><input type="text" name="mobile" placeholder="请输入联系电话" /></view>
      </view>
      <button form-type="submit" class="app_btn" hover-class="app_btn_hover" style="margin: 60rpx 0 0;">立即提交</button>
    </form>
  </view>
</view>